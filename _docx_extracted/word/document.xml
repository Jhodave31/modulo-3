:val="000000" w:themeColor="text1"/></w:rPr><w:t>Descripción General del Proyecto</w:t></w:r></w:p><w:p w14:paraId="33B5B721" w14:textId="77777777" w:rsidR="002748CE" w:rsidRPr="00AF2B57" w:rsidRDefault="00000000"><w:pPr><w:spacing w:after="200"/><w:jc w:val="both"/><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr></w:pPr><w:r w:rsidRPr="00AF2B57"><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr><w:t>La plataforma es un sistema colaborativo de gestión para juegos de rol estilo Calabozos y Dragones, desarrollado en Django y estructurado en módulos interconectados que comparten una misma base de datos. Su propósito es ofrecer a jugadores y narradores un entorno digital donde puedan organizar, crear y vivir campañas de manera integrada.</w:t></w:r></w:p><w:p w14:paraId="5D3F434E" w14:textId="1DB9DC1D" w:rsidR="002748CE" w:rsidRPr="00AF2B57" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Ttulo1"/><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr></w:pPr><w:r w:rsidRPr="00AF2B57"><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr><w:t>Módulo Asignado a</w:t></w:r><w:r w:rsidR="001832A2"><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr><w:t xml:space="preserve"> nuestro</w:t></w:r><w:r w:rsidRPr="00AF2B57"><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr><w:t xml:space="preserve"> Grupo</w:t></w:r></w:p><w:p w14:paraId="5F05EAC4" w14:textId="77777777" w:rsidR="002748CE" w:rsidRPr="00AF2B57" w:rsidRDefault="00000000"><w:pPr><w:spacing w:after="200"/><w:jc w:val="both"/><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr></w:pPr><w:r w:rsidRPr="00AF2B57"><w:rPr><w:b/><w:bCs/><w:color w:val="000000" w:themeColor="text1"/></w:rPr><w:t xml:space="preserve">Módulo 3: </w:t></w:r><w:r w:rsidRPr="00AF2B57"><w:rPr><w:color w:val="000000" w:themeColor="text1"/></w:rPr><w:t>Gestión de Campañas e Historias. Este módulo facilita la creación, organización y documentación de aventuras, misiones y narrativas